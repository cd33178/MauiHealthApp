<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiHealthApp.ViewModels"
             xmlns:dto="clr-namespace:MauiHealthApp.Shared.DTOs;assembly=MauiHealthApp.Shared"
             x:Class="MauiHealthApp.Views.QuestionsPage"
             x:DataType="vm:QuestionsViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="15" RowSpacing="10">
        <!-- Search -->
        <SearchBar Grid.Row="0" Text="{Binding SearchText}" SearchCommand="{Binding SearchCommand}"
                   Placeholder="Search questions..." />

        <!-- Status -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        <!-- Questions List -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Questions}"
                        RemainingItemsThreshold="2"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:QuestionDto">
                    <Frame Margin="0,5" Padding="12" CornerRadius="8">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding QuestionText}" FontAttributes="Bold" />
                            <Label Text="{Binding AnswerText}" TextColor="Gray" FontSize="13"
                                   IsVisible="{Binding IsAnswered}" />
                            <Label Text="Awaiting answer..." TextColor="Orange" FontSize="12"
                                   IsVisible="{Binding IsAnswered, Converter={x:Null}}" />
                            <Label Text="{Binding CreatedAt, StringFormat='{0:MMM dd, yyyy}'}"
                                   FontSize="11" TextColor="LightGray" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Ask Question -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Entry Grid.Column="0" Text="{Binding NewQuestionText}"
                   Placeholder="Ask a health question..." />
            <Button Grid.Column="1" Text="Ask" Command="{Binding AskQuestionCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#007BFF" TextColor="White" CornerRadius="8" />
        </Grid>
    </Grid>
</ContentPage>
