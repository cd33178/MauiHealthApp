<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MauiHealthApp.Views"
       x:Class="MauiHealthApp.AppShell"
       Shell.NavBarIsVisible="true">

    <ShellContent Title="Login" Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />

    <TabBar>
        <ShellContent Title="Profile" Route="profile" ContentTemplate="{DataTemplate views:ProfilePage}"
                      Icon="profile_icon.png" />
        <ShellContent Title="Q&amp;A" Route="questions" ContentTemplate="{DataTemplate views:QuestionsPage}"
                      Icon="question_icon.png" />
    </TabBar>
</Shell>
